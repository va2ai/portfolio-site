# Application
APP_NAME=ai-agent-platform
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai-agent-platform

# Redis (optional)
REDIS_URL=redis://localhost:6379/0

# --- LLM Provider Keys ---
GOOGLE_API_KEY=

# --- Tools ---
TAVILY_API_KEY=

# --- Vector Database ---
PGVECTOR_CONNECTION=postgresql://postgres:postgres@localhost:5432/ai-agent-platform

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Default LLM
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_MODEL=gemini-3.1-pro-preview
